# Database
DATABASE_URL=postgresql+asyncpg://prime_ei:prime_ei_dev_password@localhost:5432/prime_enterprise_intelligence
DATABASE_URL_SYNC=postgresql://prime_ei:prime_ei_dev_password@localhost:5432/prime_enterprise_intelligence

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=prime_ei_documents

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-opus-4-6-20250529

# Auth
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Azure AD (optional)
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=prime-ei-data

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# App
APP_NAME=Prime Enterprise Intelligence
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
